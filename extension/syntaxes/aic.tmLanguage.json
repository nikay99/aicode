{
  "name": "AICode",
  "scopeName": "source.aic",
  "fileTypes": ["aic"],
  "patterns": [
    {
      "name": "comment.line",
      "match": "#.*$"
    },
    {
      "name": "keyword.control",
      "match": "\\b(if|else|for|while|match|return|struct|enum|fn|let|const|mut|import|as|where)\\b"
    },
    {
      "name": "constant.language",
      "match": "\\b(true|false|null)\\b"
    },
    {
      "name": "constant.numeric",
      "match": "\\b(\\d+(\\.\\d+)?)\\b"
    },
    {
      "name": "string.quoted",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "entity.name.function",
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)"
    },
    {
      "name": "entity.name.type",
      "match": "\\b(struct|enum)\\s+([A-Z][a-zA-Z0-9_]*)"
    },
    {
      "name": "variable.other",
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b"
    },
    {
      "name": "variable.parameter",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)"
    },
    {
      "name": "support.type",
      "match": "\\b(int|float|str|bool|List|Dict|Option|Result)\\b"
    },
    {
      "name": "keyword.operator",
      "match": "(\\+|-|\\*|/|%|=|==|!=|>|<|>=|<=|and|or|not|in|is|->|=>|\\||::|:)"
    },
    {
      "name": "punctuation.brackets",
      "match": "[\\{\\}\\[\\]\\(\\)]"
    },
    {
      "name": "punctuation.separator",
      "match": "[,;.]"
    },
    {
      "name": "entity.name.tag",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    }
  ],
  "repository": {
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted",
      "patterns": [
        {
          "name": "constant.character.escape",
          "match": "\\\\."
        }
      ]
    }
  }
}